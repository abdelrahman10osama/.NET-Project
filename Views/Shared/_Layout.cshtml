<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ITI System</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body {
            background: #f4f6f9;
            min-height: 100vh;
        }

        .navbar {
            background: linear-gradient(90deg,#0d6efd,#6610f2);
            box-shadow: 0 5px 15px rgba(0,0,0,.2);
        }

        .navbar-brand {
            font-size: 26px;
            font-weight: bold;
            letter-spacing: 1px;
        }

        .nav-link {
            color: white !important;
            margin-right: 8px;
            border-radius: 8px;
            transition: .3s;
            padding: 8px 15px !important;
        }

            .nav-link:hover {
                background: rgba(255,255,255,.15);
            }

        .btn-custom {
            border-radius: 25px;
            padding: 8px 18px;
            font-weight: 600;
            transition: .3s;
        }

            .btn-custom:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(0,0,0,.2);
            }

        .content-card {
            background: white;
            border-radius: 15px;
            padding: 30px;
            margin-top: 30px;
            box-shadow: 0 5px 20px rgba(0,0,0,.1);
        }

        footer {
            margin-top: 50px;
            background: white;
            padding: 20px;
            text-align: center;
            box-shadow: 0 -2px 10px rgba(0,0,0,.05);
        }
    </style>

</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark">

        <div class="container">

            <a class="navbar-brand"
               asp-controller="Home"
               asp-action="Index">
                🚀 ITI System
            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navMenu">

                <ul class="navbar-nav me-auto">

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Home"
                           asp-action="Index">
                            🏠 Home
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Instructor"
                           asp-action="Index">
                            👨‍🏫 Instructors
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Course"
                           asp-action="Index">
                            📚 Courses
                        </a>
                    </li>

                </ul>

                <ul class="navbar-nav align-items-center">

                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item me-3">
                            <span class="text-white fw-bold">
                                👋 Welcome, @User.Identity.Name
                            </span>
                        </li>

                        <li class="nav-item me-2">
                            <a class="btn btn-light btn-custom"
                               asp-controller="Instructor"
                               asp-action="New">
                                ➕ Instructor
                            </a>
                        </li>

                        <li class="nav-item me-2">
                            <a class="btn btn-warning btn-custom"
                               asp-controller="Course"
                               asp-action="New">
                                ➕ Course
                            </a>
                        </li>

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item me-2">
                                <a class="btn btn-success btn-custom"
                                   asp-controller="Department"
                                   asp-action="Index">
                                    ⚙ Admin
                                </a>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="btn btn-danger btn-custom"
                               asp-controller="Account"
                               asp-action="Logout">
                                🚪 Logout
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item me-2">
                            <a class="btn btn-outline-light btn-custom"
                               asp-controller="Account"
                               asp-action="Login">
                                🔑 Login
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="btn btn-success btn-custom"
                               asp-controller="Account"
                               asp-action="Register">
                                📝 Register
                            </a>
                        </li>
                    }

                </ul>

            </div>

        </div>

    </nav>

    <div class="container">

        <div class="content-card">

            @RenderBody()

        </div>

    </div>

    <footer>

        <h5 class="mb-2">
            🚀 ITI Company Management System
        </h5>

        <small class="text-muted">
            © @DateTime.Now.Year All Rights Reserved
        </small>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>