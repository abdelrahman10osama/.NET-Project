@model List<WebApplication2.Models.instructor>

@{
    ViewData["Title"] = "بيانات المدرسين";
}

<div class="container mt-4" dir="rtl">
    <h2 class="mb-3">تفاصيل بيانات المدرس</h2>

    <table class="table table-bordered table-striped text-center mt-3">
        <thead class="table-dark">
            <tr>
                <th>الرقم (ID)</th>
                <th>الاسم</th>
                <th>المرتب (Salary)</th>
                <th>العنوان (Address)</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Name</td>
                        <td>@item.Salary</td>
                        <td>@item.Adress</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4">لا توجد بيانات لهذا المدرس.</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-3">
        <a href="/instructor/index" class="btn btn-secondary">العودة لكل المدرسين</a>
    </div>
</div>